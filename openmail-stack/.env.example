MAIL_DOMAIN=example.com
MAIL_FQDN=mail.example.com
POSTMASTER_ADDRESS=postmaster@example.com

# Roundcube webmail will be served on this host port.
ROUNDCUBE_HTTP_PORT=8080

# Mailbox and database secrets. Replace every value before deploying.
ROUNDCUBE_DB_NAME=roundcube
ROUNDCUBE_DB_USER=roundcube
ROUNDCUBE_DB_PASSWORD=change-me-roundcube-db-password
ROUNDCUBE_DES_KEY=change-me-24-char-secret

# Docker Mailserver tuning.
TZ=America/Los_Angeles
ENABLE_CLAMAV=0
